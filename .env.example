# Copy this file to `.env` and edit the values to match your setup.
#   cp .env.example .env

# LLM provider used by src/services/llmService.ts.
# Supported values: ollama
# Default: ollama
VITE_LLM_PROVIDER=ollama

# Ollama model tag to call (must already be pulled locally: `ollama pull <model>`).
# Default: llama3.1:8b
VITE_OLLAMA_MODEL=llama3.1:8b

# Base URL of the Ollama HTTP API. Override if Ollama runs on a different
# host/port or behind a tunnel.
# Default: http://localhost:11434
VITE_OLLAMA_BASE_URL=http://localhost:11434
